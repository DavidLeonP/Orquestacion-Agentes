# Copia este archivo a .env y completa los valores
OPENAI_API_KEY=sk-...

# Modelos (opcionales, valores por defecto)
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Observabilidad (opcional)
# LOG_LEVEL=INFO
# LOG_VERBOSE=true          # eventos detallados en consola

# LangSmith — trazas en la nube (https://smith.langchain.com)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=orquestacion-agentes-educacion
