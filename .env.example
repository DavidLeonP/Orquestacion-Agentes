# Copia este archivo a .env y completa los valores

# --- Model registry (perfiles de recurso) ---
# cloud_openai | local_barato | local_calidad
LLM_PROFILE=cloud_openai

# Overrides opcionales (si se definen, pisan el perfil)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# Ollama local (perfil local_* )
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# ollama pull qwen2.5:7b && ollama pull nomic-embed-text

# OpenAI (perfil cloud o si usas provider openai)
OPENAI_API_KEY=sk-...

# Observabilidad (opcional)
# LOG_LEVEL=INFO
# LOG_VERBOSE=true

# LangSmith (opcional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=orquestacion-agentes-educacion

# MySQL + API
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE
JWT_SECRET=cambia-este-secreto
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=*

# UI Streamlit (cliente HTTP de la API JWT)
# Local: http://127.0.0.1:8000
# En Docker (compose/red interna) el script de deploy fuerza http://asistente-ia-educacion:8000
STREAMLIT_API_BASE_URL=http://127.0.0.1:8000

# SSH / despliegue remoto (no subir contraseñas al repo)
# SSH_HOST=146.190.151.125
# SSH_USER=root
# SSH_PORT=22
# SSH_PASSWORD=
# DEPLOY_PATH=/opt/asistente-ia
# API_BASE_URL=http://146.190.151.125:8000
# CONTAINER_NAME=asistente-ia-educacion
# UI_CONTAINER_NAME=asistente-ia-ui
# DOCKER_IMAGE=asistente-ia_asistente:latest
# DOCKER_NETWORK=asistente-net
